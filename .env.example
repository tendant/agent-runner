# Agent Runner Configuration
# Copy to .env and customize

# --- Git ---
# GIT_HOST=git.example.com
# GIT_ORG=myorg

# --- Agent ---
# AGENT_SYSTEM_PROMPT=./agent.md
# AGENT_PROMPT_FILE=./prompt.md
# AGENT_SHARED_REPOS=sites-config
# AGENT_MAX_ITERATIONS=50
# AGENT_MAX_TOTAL_SECONDS=3600
# AGENT_MAX_ITERATION_SECONDS=300
# AGENT_PLANNER_ENABLED=false
# AGENT_REVIEWER_ENABLED=false

# --- API ---
# BIND=127.0.0.1:8080
# API_KEY=

# --- Ollama / custom provider (optional) ---
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_AUTH_TOKEN=ollama
# AGENT_MODEL=qwen3-coder:30b

# --- Stream bot (optional, connects to agent-stream server) ---
# STREAM_SERVER_URL=
# STREAM_BOT_TOKEN=
# STREAM_CONVERSATION_IDS=

# --- Telegram bot (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=
