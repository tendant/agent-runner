# Agent Runner Configuration
# Copy to .env and customize.
#
# Data directory: all mutable state (logs, repo-cache, tmp, memory, .env.local)
# defaults to ~/.agent-runner/. Override with DATA_DIR.
# In Docker, mount /root as a volume to persist data across image updates:
#   docker run -v agent-data:/root ...
#
# Multiple instances: set INSTANCE to isolate data and config per instance.
#   INSTANCE=prod   → loads .env.prod, defaults DATA_DIR to ~/.agent-runner/prod
#   INSTANCE=staging → loads .env.staging, defaults DATA_DIR to ~/.agent-runner/staging
#
# Load priority: OS env > DATA_DIR/.env.local > .env.<instance> > .env
#
# INSTANCE=                    # instance name; drives data dir scoping and .env.<instance> loading
# DATA_DIR=~/.agent-runner     # base dir for all mutable data (default: ~/.agent-runner[/<instance>])
# MEMORY_DIR=                  # override memory dir (default: DATA_DIR/memory)
# LOGS_ROOT=                   # override logs dir (default: DATA_DIR/logs)
# REPO_CACHE_ROOT=              # override repo cache dir (default: DATA_DIR/repo-cache)
# TMP_ROOT=                    # override tmp dir (default: DATA_DIR/tmp)
#
# --- Configure via chat (bot must be connected) ---
# Use these commands in Telegram / WeChat / stream to configure without SSH:
#
#   /config                          show current settings and ready status
#   /install-cli [opencode|claude|codex]  install the agent CLI binary
#   /bootstrap                       create agent.md + prompt.md from defaults
#   /set KEY VALUE                   write KEY=VALUE to .env.local (live + survives restart)
#
# Quick setup via chat:
#   /set DEEPSEEK_API_KEY sk-...
#   /set AGENT_PROVIDER deepseek
#   /set AGENT_MODEL deepseek-v4-flash
#   /install-cli opencode
#   /bootstrap

# --- Git ---
# GIT_HOST=git.example.com
# GIT_ORG=myorg

# --- Memory ---
# On first run, embedded defaults (SOUL.md, IDENTITY.md, etc.) are seeded
# into ./memory/. After that, ./memory/ is the single source of truth.
# Daily session logs are written to ./memory/YYYY-MM-DD.md.

# --- Agent ---
# AGENT_CLI=opencode                  # CLI backend: "opencode" (default), "claude", or "codex" — model format varies, see AGENT_MODEL below
# AGENT_SYSTEM_PROMPT=./agent.md
# AGENT_PROMPT_FILE=./prompt.md
# AGENT_SHARED_REPOS=sites-config
# AGENT_SKILLS_DIR=                   # Path to a directory of SKILL.md skills pre-populated in every workspace (works with claude, opencode, codex)
# AGENT_MAX_ITERATIONS=50
# AGENT_MAX_TOTAL_SECONDS=3600
# AGENT_MAX_ITERATION_SECONDS=300
# AGENT_PLANNER_ENABLED=false
# AGENT_REVIEWER_ENABLED=false

# --- API ---
# BIND=127.0.0.1:8080
# API_KEY=

# --- Agent models ---
# Two models are used:
#   AGENT_MODEL           — fast model for the main iteration loop (default: deepseek-v4-flash)
#   AGENT_REASONING_MODEL — capable model for planner + reviewer sub-agents (default: deepseek-v4-pro)
#
# AGENT_PROVIDER / AGENT_REASONING_PROVIDER set the provider (opencode only).
# When both provider and model are set, opencode receives "--model provider/model".
# When only model is set, it is passed as-is (use full "provider/model" form for opencode).
# AGENT_REASONING_PROVIDER defaults to AGENT_PROVIDER; AGENT_REASONING_MODEL defaults to deepseek-v4-pro.
#
# Recommended: opencode + deepseek (default)
#   AGENT_CLI=opencode
#   AGENT_PROVIDER=deepseek
#   AGENT_MODEL=deepseek-v4-flash        # fast — main iteration loop
#   AGENT_REASONING_MODEL=deepseek-v4-pro  # capable — planner + reviewer
#
# Anthropic via opencode:
#   AGENT_PROVIDER=anthropic
#   AGENT_MODEL=claude-haiku-4-5-20251001   # fast
#   AGENT_REASONING_MODEL=claude-opus-4-7   # capable
#
# OpenRouter:
#   AGENT_PROVIDER=openrouter
#   AGENT_MODEL=deepseek/deepseek-chat
#   AGENT_REASONING_MODEL=deepseek/deepseek-r1
#
# claude CLI — model name only, no provider:
#   AGENT_CLI=claude
#   AGENT_MODEL=claude-sonnet-4-6
#   AGENT_REASONING_MODEL=claude-opus-4-7
#
# codex CLI — model name only, no provider:
#   AGENT_CLI=codex
#   AGENT_MODEL=o4-mini
#   AGENT_REASONING_MODEL=o3
#
# AGENT_PROVIDER=deepseek
# AGENT_MODEL=deepseek-v4-flash
# AGENT_REASONING_PROVIDER=          # defaults to AGENT_PROVIDER
# AGENT_REASONING_MODEL=deepseek-v4-pro

# --- Provider API keys (opencode backend) ---
# agent-runner loads .env via os.Setenv so all vars are inherited by every CLI
# subprocess — no separate per-CLI config needed. opencode recognises these natively.
#
# ANTHROPIC_API_KEY=          # provider: anthropic
# OPENAI_API_KEY=             # provider: openai  (also used by codex backend)
# DEEPSEEK_API_KEY=           # provider: deepseek
# OPENROUTER_API_KEY=         # provider: openrouter
# GEMINI_API_KEY=             # provider: google/gemini
# GROQ_API_KEY=               # provider: groq
# MISTRAL_API_KEY=            # provider: mistral
# OLLAMA_API_KEY=             # provider: ollama  (usually "ollama" or empty)
#
# Generic / custom OpenAI-compatible provider:
# opencode has no env var for an arbitrary baseURL, so a custom provider must be
# declared once in ~/.config/opencode/opencode.json:
#   {
#     "provider": {
#       "myprovider": {
#         "name": "My Provider",
#         "baseURL": "https://api.example.com/v1",
#         "apiKey": "${MYPROVIDER_API_KEY}"
#       }
#     }
#   }
# Then just set the key here and pick the model:
# MYPROVIDER_API_KEY=
# AGENT_CLI=opencode
# AGENT_MODEL=myprovider/model-name

# --- Ollama / custom provider (claude backend) ---
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_AUTH_TOKEN=ollama
# AGENT_MODEL=qwen3-coder:30b

# --- Runner (optional, durable task execution via simple-workflow) ---
# RUNNER_SCHEDULER_ENABLED=false
# RUNNER_DATABASE_URL=sqlite:///tmp/agent-runner.db
# RUNNER_AGENT_ID=                   # default: hostname-pid
# RUNNER_LEASE_DURATION=60           # seconds
# RUNNER_POLL_CAP=30                 # seconds
# RUNNER_HEARTBEAT_INTERVAL=300      # seconds
# RUNNER_MAX_ATTEMPTS=10
# RUNNER_TYPE_PREFIX=agent.

# --- Stream bot (optional, connects to agent-stream server) ---
# STREAM_SERVER_URL=
# STREAM_BOT_TOKEN=
# STREAM_CONVERSATION_IDS=

# --- Telegram bot (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- WeChat bot (optional, iLink API) ---
# Run without WECHAT_TOKEN to trigger interactive QR login and get a token.
# WECHAT_TOKEN=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c   # media CDN (rarely needs changing)
# WECHAT_STATE_DIR=./tmp            # directory for getupdates cursor; defaults to TMP_ROOT

# Analyzer LLM (fast intent routing before launching the agent)
# Auto-detects from ANTHROPIC_API_KEY / OPENAI_API_KEY if ANALYZER_PROVIDER is not set.
# Falls back to the agent CLI (claude/codex) when no API key is available.
# ANALYZER_PROVIDER=anthropic        # "anthropic" | "openai"
# ANALYZER_MODEL=claude-haiku-4-5-20251001
# ANALYZER_API_KEY=                  # defaults to ANTHROPIC_API_KEY or OPENAI_API_KEY
# ANALYZER_BASE_URL=                 # override endpoint (e.g. http://localhost:11434 for Ollama)
# ANALYZER_TIMEOUT_SECONDS=30        # per-call timeout; increase for slow local models
