# Agent Runner Configuration
# Copy to .env — every line below is commented out (optional); uncomment only what you need.
#
# ── Quick start ────────────────────────────────────────────────────────────────
# Option A — opencode + DeepSeek (default, recommended):
#   DEEPSEEK_API_KEY=sk-...
#
# Option B — Claude Code (if already installed and authenticated via `claude login`):
#   AGENT_CLI=claude
#   (no API key needed here — claude manages its own credentials)
#
# Option C — configure via chat without SSH (bot must be connected first):
#   /set DEEPSEEK_API_KEY sk-...
#   /install-cli opencode
#   /bootstrap
#
# For git push/fetch against a self-hosted server, also add:
#   GIT_HOST=git.example.com
#   GIT_ORG=myorg
#   GIT_TOKEN=your-personal-access-token   # or GIT_SSH_KEY for SSH
# ──────────────────────────────────────────────────────────────────────────────
#
# Everything below is the full reference, grouped by category. See README.md
# for narrative walkthroughs (Docker, Agent Stream). Once a bot is connected
# you can configure a running instance without SSH:
#   /config      show current settings and ready status
#   /set KEY VALUE   write KEY=VALUE to .env.local (live + survives restart)
#   /install-cli [opencode|claude|codex]   install the agent CLI binary
#   /bootstrap   one-shot setup: installs the AGENT_CLI binary if missing,
#                creates agent.md + prompt.md from defaults, reports readiness
#   /status      runtime + readiness check

# --- Data directories ---
# All mutable state (logs, repo-cache, tmp, memory, outputs, uploads, .env.local)
# lives under DATA_DIR (default: current dir, or ~/.agent-runner/<instance> when
# INSTANCE is set). In Docker, mount /data as a volume and set DATA_DIR=/data so
# state survives image updates: docker run -v agent-data:/data -e DATA_DIR=/data ...
# Load priority: OS env > DATA_DIR/.env.local > .env.<instance> > .env
# INSTANCE=                    # instance name; loads .env.<instance>, scopes default DATA_DIR
# DATA_DIR=                    # base dir for all mutable data (default: CWD, or ~/.agent-runner[/<instance>])
# MEMORY_DIR=                  # default: DATA_DIR/memory
# LOGS_ROOT=                   # default: DATA_DIR/logs
# REPO_CACHE_ROOT=             # default: DATA_DIR/repo-cache
# TMP_ROOT=                    # default: DATA_DIR/tmp
# OUTPUTS_ROOT=                # default: DATA_DIR/outputs — _send/ files persisted here across sessions
# UPLOADS_ROOT=                # default: DATA_DIR/uploads — user-uploaded files (images, docs)
# ALLOWED_PROJECTS=            # comma-separated project allowlist (default: all allowed)

# --- Git ---
# GIT_HOST=git.example.com
# GIT_ORG=myorg
# GIT_TOKEN=                            # HTTPS token injected into repo remote URLs at runtime
# GIT_SSH_KEY=                          # path to SSH private key for repo operations
# GIT_PUSH_RETRIES=3                    # retry attempts on push failure
# GIT_PUSH_RETRY_DELAY_SECONDS=5

# --- Jobs & cleanup ---
# JOB_MAX_RUNTIME=300                   # seconds; max runtime for a one-shot /run job
# JOB_MAX_CONCURRENT=5                  # max concurrent one-shot jobs
# JOB_RETENTION_SECONDS=3600            # how long finished jobs/sessions stay queryable
# CLEANUP_STALE_JOBS=true               # sweep stale jobs on startup
# LOG_RETENTION_DAYS=30                 # delete audit log files older than N days (0 = keep forever)
# VALIDATION_BLOCK_BINARY_FILES=false   # reject binary-file diffs from agent output
# VALIDATION_BLOCKED_PATHS=.git/,.github/,.gitlab-ci.yml,secrets/,*.env

# --- Memory ---
# On first run, embedded defaults (SOUL.md, IDENTITY.md, etc.) are seeded into
# MEMORY_DIR; after that it's the single source of truth. Daily session logs
# are written to MEMORY_DIR/YYYY-MM-DD-<hostname>.md.
# AGENT_MEMORY_PULL_ON_START=true       # pull memory git remote before each session
# AGENT_MEMORY_DAYS=7                   # days of daily logs folded into prompts as "Recent Sessions"
# AGENT_MEMORY_CHAR_CAP=12000           # max chars of memory content per prompt; 0=no limit (files on disk untouched)
# AGENT_MEMORY_CURATION_ENABLED=false   # post-session LLM pass: distills lessons.md, compacts over-budget
#                                       # memory files; uses the ANALYZER_* LLM config; opt-in (costs one
#                                       # small LLM call per session)
# AGENT_MEMORY_CURATION_TIMEOUT_SECONDS=60
# MEMORY_GIT_TOKEN=                     # HTTPS token for memory-repo git push/pull; falls back to GIT_TOKEN if unset
# MEMORY_GIT_USER=                      # git commit author for memory-repo ops (default: oauth2)
# MEMORY_GIT_SSH_KEY=                   # SSH key for memory repo; falls back to GIT_SSH_KEY if unset (or run /memory keygen)

# --- Agent / CLI ---
# AGENT_CLI=opencode                    # "opencode" (default), "claude", or "codex"
# AGENT_SYSTEM_PROMPT=./agent.md        # seeded into the template system at startup
# AGENT_PROMPT_FILE=./prompt.md
# AGENT_SHARED_REPOS=sites-config       # comma-separated repos pre-populated in every workspace
# AGENT_SKILLS_DIR=                     # dir of SKILL.md skills pre-populated in every workspace
# AGENT_PATHS=                          # comma-separated allowed paths for agent sessions (default: all)
# AGENT_AUTHOR=claude-agent             # git commit author for agent-made commits
# AGENT_COMMIT_PREFIX=[agent]
# AGENT_MAX_ITERATIONS=20
# AGENT_MAX_TOTAL_SECONDS=3600
# AGENT_MAX_ITERATION_SECONDS=300
# AGENT_MAX_TURNS=50                    # --max-turns passed to each CLI invocation
# AGENT_MAX_QUEUE_SIZE=10               # max queued agent sessions
# AGENT_PLANNER_ENABLED=true            # run planner sub-agent before the iteration loop
# AGENT_REVIEWER_ENABLED=false          # run reviewer sub-agent after the iteration loop
# PLANNER_API_KEY=                      # optional: API key for the planner/reviewer sub-agent LLM
# PLANNER_BASE_URL=                     # optional: base URL override for the same
#
# POST /agent and chat sessions refuse to start (412 / chat error) if the
# AGENT_CLI binary isn't installed — see README.md Prerequisites. Missing
# credentials aren't blocking (some setups authenticate outside an API key
# env var) but surface as non-fatal warnings; check readiness with /status
# or POST /bootstrap.

# --- API ---
# API_BIND=127.0.0.1:8080
# API_KEY=                              # optional bearer token auth for the REST API

# --- Agent models & providers ---
# Two model slots: AGENT_MODEL (fast — planning / chat-level responses when no
# fast-LLM API key is configured) and AGENT_REASONING_MODEL (the model that
# actually reaches the agent CLI for real task iterations; defaults to
# AGENT_MODEL if unset). AGENT_PROVIDER / AGENT_REASONING_PROVIDER select the
# provider (opencode only) — when both are set, opencode gets "--model provider/model".
#
#   opencode + deepseek (default): AGENT_PROVIDER=deepseek AGENT_MODEL=deepseek-v4-flash AGENT_REASONING_MODEL=deepseek-v4-pro
#   opencode + anthropic:          AGENT_PROVIDER=anthropic AGENT_MODEL=claude-haiku-4-5-20251001 AGENT_REASONING_MODEL=claude-opus-4-7
#   opencode + openrouter:         AGENT_PROVIDER=openrouter AGENT_MODEL=deepseek/deepseek-chat AGENT_REASONING_MODEL=deepseek/deepseek-r1
#   claude CLI (pre-authorized):   AGENT_CLI=claude AGENT_MODEL=claude-opus-4-7
#   codex CLI (pre-authorized):    AGENT_CLI=codex AGENT_MODEL=gpt-5.5
#   ollama via claude backend:     ANTHROPIC_BASE_URL=http://localhost:11434 ANTHROPIC_AUTH_TOKEN=ollama AGENT_MODEL=qwen3-coder:30b
#
# Custom OpenAI-compatible provider: opencode has no baseURL env var, so declare
# it once in ~/.config/opencode/opencode.json (provider.myprovider.baseURL/apiKey),
# then set AGENT_MODEL=myprovider/model-name and MYPROVIDER_API_KEY= below.
#
# AGENT_PROVIDER=
# AGENT_MODEL=
# AGENT_REASONING_PROVIDER=
# AGENT_REASONING_MODEL=

# --- Provider API keys (opencode backend) ---
# Loaded via os.Setenv, so every CLI subprocess inherits them — opencode
# recognises these natively. agent-runner itself only reads them to report
# "is this provider configured?" in /config and bootstrap warnings.
# ANTHROPIC_API_KEY=
# OPENAI_API_KEY=              # also used by the codex backend
# DEEPSEEK_API_KEY=
# OPENROUTER_API_KEY=
# GEMINI_API_KEY=
# GROQ_API_KEY=
# MISTRAL_API_KEY=
# OLLAMA_API_KEY=              # usually "ollama" or empty — pass-through only, not read by agent-runner
# ANTHROPIC_AUTH_TOKEN=        # claude-CLI pass-through only, not read by agent-runner
# MYPROVIDER_API_KEY=          # placeholder — replace "MYPROVIDER" with your opencode.json provider id

# --- Analyzer (fast intent routing before launching the agent) ---
# Auto-detects from ANTHROPIC_API_KEY / OPENAI_API_KEY if ANALYZER_PROVIDER unset;
# falls back to the agent CLI itself when no API key is available.
# ANALYZER_PROVIDER=           # "anthropic" | "openai"
# ANALYZER_MODEL=claude-haiku-4-5-20251001
# ANALYZER_API_KEY=            # defaults to ANTHROPIC_API_KEY or OPENAI_API_KEY
# ANALYZER_BASE_URL=           # e.g. http://localhost:11434 for Ollama
# ANALYZER_TIMEOUT_SECONDS=30  # also scales the API server's write timeout automatically

# --- Scheduled tasks (optional, durable via simple-workflow) ---
# Disabled by default; needs a database to durably track due tasks across restarts.
# SCHEDULER_ENABLED=false
# SCHEDULER_DATABASE_URL=sqlite:///tmp/agent-runner.db
# SCHEDULER_AGENT_ID=                   # default: hostname-pid
# SCHEDULER_LEASE_DURATION=60           # seconds
# SCHEDULER_POLL_CAP=30                 # seconds
# SCHEDULER_HEARTBEAT_INTERVAL=300      # seconds
# SCHEDULER_MAX_ATTEMPTS=10
# SCHEDULER_TYPE_PREFIX=agent.

# --- Stream bot (optional, connects to agent-stream server) ---
# STREAM_SERVER_URL=
# STREAM_BOT_TOKEN=
# STREAM_CONVERSATION_IDS=
# STREAM_POLL_INTERVAL=          # e.g. "3s" — poll instead of SSE
# STREAM_STATE_DIR=              # default: TMP_ROOT — per-conversation event-seq cursor
# STREAM_MAX_CATCHUP_BACKLOG=100 # cap on messages reacted to after a reconnect gap; the
                                  # server always replays the full backlog after afterSeq,
                                  # but the cursor still advances past skipped ones so
                                  # they aren't replayed again.

# --- Telegram bot (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- WeChat bot (optional, iLink API) ---
# Run without WECHAT_TOKEN to trigger interactive QR login and get a token.
# WECHAT_TOKEN=
# WECHAT_BASE_URL=https://ilinkai.weixin.qq.com
# WECHAT_CDN_BASE_URL=https://novac2c.cdn.weixin.qq.com/c2c   # media CDN (default shown)
# WECHAT_STATE_DIR=              # default: TMP_ROOT — getupdates cursor
