# Agent Runner Configuration
# Copy to .env and customize

# --- Directory paths ---
# REPOS_ROOT=./repos
# LOGS_ROOT=./logs
# TMP_ROOT=./tmp

# --- Project allowlist (comma-separated, empty = all allowed) ---
# ALLOWED_PROJECTS=site-a,site-b

# --- Execution limits ---
# MAX_RUNTIME_SECONDS=300
# MAX_CONCURRENT_JOBS=5

# --- Git settings ---
# GIT_HOST=git.example.com
# GIT_ORG=myorg
# GIT_PUSH_RETRIES=3
# GIT_PUSH_RETRY_DELAY_SECONDS=5

# --- Validation ---
# VALIDATION_BLOCK_BINARY_FILES=false
# VALIDATION_BLOCKED_PATHS=.git/,.github/,.gitlab-ci.yml,secrets/,*.env

# --- API ---
# BIND=127.0.0.1:8080
# API_KEY=

# --- Agent mode ---
# AGENT_PROMPT_FILE=./prompt.md
# AGENT_PATHS=src/,docs/
# AGENT_AUTHOR=claude-agent
# AGENT_COMMIT_PREFIX=[agent]
# AGENT_MAX_ITERATIONS=50
# AGENT_MAX_TOTAL_SECONDS=3600
# AGENT_MAX_ITERATION_SECONDS=300
# AGENT_MODEL=                    # Optional: model name (e.g., qwen3-coder:30b for Ollama)
# AGENT_MAX_TURNS=50              # Max agentic turns per CLI invocation

# --- Ollama / custom provider (optional) ---
# Set these to route Claude Code CLI through a local Ollama instance
# ANTHROPIC_BASE_URL=http://localhost:11434
# ANTHROPIC_AUTH_TOKEN=ollama
# ANTHROPIC_API_KEY=

# --- Telegram bot (optional) ---
# TELEGRAM_BOT_TOKEN=
# TELEGRAM_CHAT_ID=

# --- Stream bot (optional, connects to agent-stream server) ---
# STREAM_SERVER_URL=
# STREAM_BOT_TOKEN=
# STREAM_CONVERSATION_IDS=           # Comma-separated conversation IDs to listen on

# --- Cleanup ---
# JOB_RETENTION_SECONDS=3600
# STARTUP_CLEANUP_STALE_JOBS=true
